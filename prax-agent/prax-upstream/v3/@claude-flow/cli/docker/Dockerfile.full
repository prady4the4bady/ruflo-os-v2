# Prady v3.5 — Full Image (includes optional dependencies)
# Use this when you need agentic-flow, RuVector, ONNX, or embeddings.
#
# Build:
#   docker build -t prady:full -f v3/@claude-flow/cli/docker/Dockerfile.full .
#
# Run:
#   docker run -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY prady:full

# ── Stage 1: Install ─────────────────────────────────────────────
FROM node:22-alpine AS build

# onnxruntime-node needs build tools on Alpine
RUN apk add --no-cache git python3 make g++

WORKDIR /install

# Full install — includes optional deps (agentic-flow, ruvector, etc.)
RUN npm install -g prady@latest \
      --no-audit \
      --no-fund \
    && npm cache clean --force

# Stage the global install for copying
RUN GLOBAL_PREFIX=$(npm config get prefix) \
    && mkdir -p /staged/lib /staged/bin \
    && cp -a "${GLOBAL_PREFIX}/lib/node_modules" /staged/lib/ \
    && cp -a "${GLOBAL_PREFIX}/bin/prady" /staged/bin/ 2>/dev/null || true \
    && cp -a "${GLOBAL_PREFIX}/bin/claude-flow" /staged/bin/ 2>/dev/null || true \
    && cp -a "${GLOBAL_PREFIX}/bin/cli" /staged/bin/ 2>/dev/null || true

# ── Stage 2: Production ──────────────────────────────────────────
FROM node:22-alpine AS production

RUN apk add --no-cache dumb-init git bash ca-certificates curl

# Non-root user
RUN addgroup -g 1001 -S prady \
    && adduser -S -D -H -u 1001 -h /home/prady -s /bin/bash -G prady prady \
    && mkdir -p /home/prady/.claude-flow /workspace /var/log/prady \
    && chown -R prady:prady /home/prady /workspace /var/log/prady

# Copy global node_modules and bin links from build stage
COPY --from=build /staged/lib/node_modules /usr/local/lib/node_modules
COPY --from=build /staged/bin/ /usr/local/bin/

# Ensure bin symlinks
RUN ln -sf /usr/local/lib/node_modules/prady/bin/prady.js /usr/local/bin/prady 2>/dev/null || true \
    && ln -sf /usr/local/lib/node_modules/@claude-flow/cli/bin/cli.js /usr/local/bin/claude-flow 2>/dev/null || true \
    && chmod +x /usr/local/bin/prady 2>/dev/null || true \
    && chmod +x /usr/local/bin/claude-flow 2>/dev/null || true

ENV NODE_ENV=production \
    CLAUDE_FLOW_LOG_LEVEL=info \
    CLAUDE_FLOW_MEMORY_BACKEND=hybrid \
    HOME=/home/prady

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD prady doctor --quiet || exit 1

USER prady
WORKDIR /workspace

EXPOSE 3000

ENTRYPOINT ["/usr/bin/dumb-init", "--"]

CMD ["prady", "daemon", "start", "--foreground"]
