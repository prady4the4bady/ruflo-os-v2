# Prady OS — Buildroot defconfig (x86_64) for v1.0.0
#
# Scope for this release: a minimal, bootable x86_64 live image that
# brings up Linux, systemd, the Prady OS userland mount points, and
# just enough container runtime to pull and start the Docker compose
# stack on first boot.
#
# Everything outside that scope (Xorg, Chromium, PulseAudio, the
# full multimedia stack, etc.) is explicitly NOT baked into the v1.0
# defconfig. Each of those lives in its own follow-up config delta
# to keep this one green against Buildroot 2024.02 and to keep the
# image under 1.5 GB.

BR2_x86_64=y
BR2_X86_CPU_COREI2CORE=y

# Build options
BR2_CCACHE=y
BR2_OPTIMIZE_S=y
BR2_JLEVEL=1

# Toolchain
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC_VERSION_2_36=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
BR2_ENABLE_LOCALE=y
BR2_ENABLE_NLS=y

# System configuration
BR2_TARGET_GENERIC_HOSTNAME="prady-os"
BR2_TARGET_GENERIC_ISSUE="Prady OS v1.0.0"
BR2_SYSTEM_DHCP="eth0"
BR2_SYSTEM_INIT_SYSTEMD=y
BR2_TARGET_TIMEZONE="UTC"

# Linux kernel — use Buildroot's stable tarball so CI doesn't depend
# on a downstream fork. The fork can be swapped back in later by
# flipping BR2_LINUX_KERNEL_LATEST_VERSION to CUSTOM_GIT.
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_USE_ARCH_DEFAULT_CONFIG=y
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
BR2_LINUX_KERNEL_NEEDS_HOST_LIBELF=y
BR2_LINUX_KERNEL_IMAGE_BZIMAGE=y

# Filesystem images
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="2G"
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS_LZMA=y
BR2_TARGET_ROOTFS_ISO9660=y
BR2_TARGET_ROOTFS_ISO9660_GRUB2=y

# Core utilities
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BASH=y
BR2_PACKAGE_COREUTILS=y
BR2_PACKAGE_LIBCURL=y
BR2_PACKAGE_LIBCURL_CURL=y
BR2_PACKAGE_WGET=y
BR2_PACKAGE_GIT=y
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_VIM=y
BR2_PACKAGE_RSYNC=y
BR2_PACKAGE_LESS=y
BR2_PACKAGE_FILE=y
BR2_PACKAGE_SUDO=y
BR2_PACKAGE_SHADOW=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_PARTED=y
BR2_PACKAGE_PROCPS_NG=y
BR2_PACKAGE_PSMISC=y

# Network
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_DHCPCD=y
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_NFTABLES=y

# Python 3 for the systemd-unit bring-up scripts.
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON_PYYAML=y

# Bootloader
BR2_TARGET_GRUB2=y
BR2_TARGET_GRUB2_X86_64_EFI=y
BR2_TARGET_GRUB2_BUILTIN_MODULES_PC="boot linux ext2 fat squash4 part_msdos part_gpt normal biosdisk gfxterm png"
BR2_TARGET_GRUB2_BUILTIN_MODULES_EFI="boot linux ext2 fat squash4 part_gpt normal efi_gop gfxterm png"
BR2_TARGET_GRUB2_NEEDS_HOST_PYTHON=y
