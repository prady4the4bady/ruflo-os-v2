#!/bin/sh
# Force genisoimage to always include -allow-limited-size.
# This is needed because filesystem.squashfs can exceed 4GiB.
# Use /usr/bin replacement so hardcoded calls are also covered.
set -e

if [ ! -x /usr/bin/genisoimage ]; then
	exit 0
fi

if [ ! -e /usr/bin/genisoimage.real ]; then
	mv /usr/bin/genisoimage /usr/bin/genisoimage.real
fi

cat > /usr/bin/genisoimage << 'EOF'
#!/bin/sh
exec /usr/bin/genisoimage.real -allow-limited-size "$@"
EOF

chmod +x /usr/bin/genisoimage
