#!/bin/bash
# Start all PradyOS services and launch Hyprland
export WAYLAND_DISPLAY=wayland-1
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=prady

# Source user Hyprland config from PradyOS config dir
export HYPRLAND_CONFIG=/etc/prady/hyprland/hyprland.conf

# Start supporting daemons if not running
systemctl --user start pipewire pipewire-pulse wireplumber

# Launch Hyprland (it reads startup.conf which starts AGS + prax-agent)
exec Hyprland
