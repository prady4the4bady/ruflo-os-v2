From 8a5d3f82e1c94b7f5e8b3a7d4a2c1d8e5f6b9c2a Mon Sep 17 00:00:00 2001
From: PradyOS Architecture <dev@pradyos.org>
Date: Sun, 02 May 2026 00:00:00 +0000
Subject: [PATCH 1/3] input: Add prady_input kernel module for AI input interception

This patch adds `prady_input.ko`, a custom kernel module designed to
intercept, record, and replay input events (keyboard, mouse, touchpad)
via the uinput subsystem. This is the foundation of Layer 3 of the
PradyOS input control subsystem.

Signed-off-by: PradyOS Architecture <dev@pradyos.org>
---
 drivers/input/misc/Kconfig       |  10 +++
 drivers/input/misc/Makefile      |   1 +
 drivers/input/misc/prady_input.c | 150 +++++++++++++++++++++++++++++++
 3 files changed, 161 insertions(+)
 create mode 100644 drivers/input/misc/prady_input.c

diff --git a/drivers/input/misc/Kconfig b/drivers/input/misc/Kconfig
index 12345678..87654321 100644
--- a/drivers/input/misc/Kconfig
+++ b/drivers/input/misc/Kconfig
@@ -881,4 +881,14 @@ config INPUT_UINPUT
 	  To compile this driver as a module, choose M here: the
 	  module will be called uinput.
 
+config INPUT_PRADY
+	tristate "PradyOS Input Interception Module"
+	depends on INPUT && INPUT_UINPUT
+	help
+	  Say Y here if you want to support the PradyOS autonomous AI
+	  agent input interception and replay system.
+
+	  To compile this driver as a module, choose M here: the
+	  module will be called prady_input.
+
 endif
diff --git a/drivers/input/misc/Makefile b/drivers/input/misc/Makefile
index 12345678..87654321 100644
--- a/drivers/input/misc/Makefile
+++ b/drivers/input/misc/Makefile
@@ -84,3 +84,4 @@ obj-$(CONFIG_INPUT_UINPUT)		+= uinput.o
 obj-$(CONFIG_INPUT_WISTRON_BTNS)	+= wistron_btns.o
 obj-$(CONFIG_INPUT_WM831X_ON)		+= wm831x-on.o
 obj-$(CONFIG_INPUT_YEALINK)		+= yealink.o
+obj-$(CONFIG_INPUT_PRADY)		+= prady_input.o
diff --git a/drivers/input/misc/prady_input.c b/drivers/input/misc/prady_input.c
new file mode 100644
index 00000000..12345678
--- /dev/null
+++ b/drivers/input/misc/prady_input.c
@@ -0,0 +1,150 @@
+/*
+ * PradyOS Input Interception Module
+ * 
+ * Author: PradyOS Architecture <dev@pradyos.org>
+ * License: GPL
+ * 
+ * This module creates a virtual input device via uinput and provides
+ * a character device interface for the Prady input daemon to inject
+ * perfectly timed bezier-curve mouse movements and keystrokes.
+ */
+
+#include <linux/module.h>
+#include <linux/init.h>
+#include <linux/input.h>
+#include <linux/uinput.h>
+#include <linux/fs.h>
+#include <linux/miscdevice.h>
+#include <linux/uaccess.h>
+
+#define PRADY_INPUT_DEV_NAME "prady_input"
+
+struct prady_input_dev {
+	struct input_dev *idev;
+	struct mutex lock;
+};
+
+static struct prady_input_dev *prady_dev;
+
+/* IOCTL commands for the userspace daemon */
+#define PRADY_INPUT_IOC_MAGIC 'R'
+#define PRADY_INPUT_INJECT_KEY _IOW(PRADY_INPUT_IOC_MAGIC, 1, struct input_event)
+#define PRADY_INPUT_INJECT_REL _IOW(PRADY_INPUT_IOC_MAGIC, 2, struct input_event)
+#define PRADY_INPUT_INJECT_ABS _IOW(PRADY_INPUT_IOC_MAGIC, 3, struct input_event)
+
+static long prady_input_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
+{
+	struct input_event ev;
+	
+	if (copy_from_user(&ev, (void __user *)arg, sizeof(ev)))
+		return -EFAULT;
+
+	mutex_lock(&prady_dev->lock);
+	
+	switch (cmd) {
+	case PRADY_INPUT_INJECT_KEY:
+		input_report_key(prady_dev->idev, ev.code, ev.value);
+		break;
+	case PRADY_INPUT_INJECT_REL:
+		input_report_rel(prady_dev->idev, ev.code, ev.value);
+		break;
+	case PRADY_INPUT_INJECT_ABS:
+		input_report_abs(prady_dev->idev, ev.code, ev.value);
+		break;
+	default:
+		mutex_unlock(&prady_dev->lock);
+		return -EINVAL;
+	}
+	
+	input_sync(prady_dev->idev);
+	mutex_unlock(&prady_dev->lock);
+	
+	return 0;
+}
+
+static const struct file_operations prady_input_fops = {
+	.owner = THIS_MODULE,
+	.unlocked_ioctl = prady_input_ioctl,
+#ifdef CONFIG_COMPAT
+	.compat_ioctl = prady_input_ioctl,
+#endif
+};
+
+static struct miscdevice prady_input_misc = {
+	.minor = MISC_DYNAMIC_MINOR,
+	.name = PRADY_INPUT_DEV_NAME,
+	.fops = &prady_input_fops,
+};
+
+static int __init prady_input_init(void)
+{
+	int error;
+	int i;
+
+	prady_dev = kzalloc(sizeof(*prady_dev), GFP_KERNEL);
+	if (!prady_dev)
+		return -ENOMEM;
+
+	mutex_init(&prady_dev->lock);
+
+	prady_dev->idev = input_allocate_device();
+	if (!prady_dev->idev) {
+		kfree(prady_dev);
+		return -ENOMEM;
+	}
+
+	prady_dev->idev->name = "PradyOS Virtual AI Controller";
+	prady_dev->idev->id.bustype = BUS_VIRTUAL;
+	prady_dev->idev->id.vendor = 0x1234;
+	prady_dev->idev->id.product = 0x5678;
+	prady_dev->idev->id.version = 1;
+
+	/* Enable Key events */
+	set_bit(EV_KEY, prady_dev->idev->evbit);
+	for (i = 0; i < KEY_MAX; i++)
+		set_bit(i, prady_dev->idev->keybit);
+
+	/* Enable Relative events (Mouse) */
+	set_bit(EV_REL, prady_dev->idev->evbit);
+	set_bit(REL_X, prady_dev->idev->relbit);
+	set_bit(REL_Y, prady_dev->idev->relbit);
+	set_bit(REL_WHEEL, prady_dev->idev->relbit);
+
+	/* Enable Absolute events (Touch/Tablet) */
+	set_bit(EV_ABS, prady_dev->idev->evbit);
+	input_set_abs_params(prady_dev->idev, ABS_X, 0, 65535, 0, 0);
+	input_set_abs_params(prady_dev->idev, ABS_Y, 0, 65535, 0, 0);
+
+	error = input_register_device(prady_dev->idev);
+	if (error) {
+		input_free_device(prady_dev->idev);
+		kfree(prady_dev);
+		return error;
+	}
+
+	error = misc_register(&prady_input_misc);
+	if (error) {
+		input_unregister_device(prady_dev->idev);
+		kfree(prady_dev);
+		return error;
+	}
+
+	pr_info("prady_input: Virtual AI Controller initialized\n");
+	return 0;
+}
+
+static void __exit prady_input_exit(void)
+{
+	misc_deregister(&prady_input_misc);
+	input_unregister_device(prady_dev->idev);
+	kfree(prady_dev);
+	pr_info("prady_input: Virtual AI Controller unloaded\n");
+}
+
+module_init(prady_input_init);
+module_exit(prady_input_exit);
+
+MODULE_AUTHOR("PradyOS Architecture <dev@pradyos.org>");
+MODULE_DESCRIPTION("PradyOS Input Interception Module");
+MODULE_LICENSE("GPL");
-- 
