# Prady Orchestration Engine — environment variables

# Redis (required)
REDIS_URL=redis://localhost:6379

# Phase 1 model-gateway (required)
MODEL_GATEWAY_URL=http://localhost:11430

# Model to use for goal decomposition and summarisation
GATEWAY_MODEL=llama3.2:3b

# Directory for activity.jsonl
ACTIVITY_LOG_DIR=./logs

# Seconds to wait for a human approval before timing out
APPROVAL_TIMEOUT_SECONDS=300
