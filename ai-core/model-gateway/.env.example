# Environment variables for model-gateway
# Copy this to .env and fill in your keys.

# Routing mode override (overrides config/routing-policy.yaml if set)
# GATEWAY_ROUTING_MODE=local-first

# Directory overrides (absolute paths)
# GATEWAY_CONFIG_DIR=/path/to/config
# GATEWAY_LOG_DIR=/path/to/logs

# Cloud provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama base URL override (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
