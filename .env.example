# ─────────────────────────────────────────────────────────────────────────────
# Prady OS unified environment variables (Phases 1–5)
# Copy to .env and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# Global logging
LOG_LEVEL=INFO

# ── Phase 1: model-gateway ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GATEWAY_ROUTING_MODE=local-first
GATEWAY_CONFIG_DIR=/app/config
GATEWAY_LOG_DIR=/app/logs
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Phase 2: workflow-engine ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
MODEL_GATEWAY_URL=http://model-gateway:8000
PLAYWRIGHT_RUNNER_URL=http://host.docker.internal:11432
GATEWAY_MODEL=llama3.2:3b
ACTIVITY_LOG_DIR=/app/logs
APPROVAL_TIMEOUT_SECONDS=300

# ── Phase 3: screen-agent / operator ─────────────────────────────────────────
WORKFLOW_ENGINE_URL=http://workflow-engine:8000
SCREEN_AGENT_MODEL_GATEWAY_URL=http://model-gateway:8000
ACTION_POLICY=
POLICY_TIMEOUT_SECS=5
VISION_MODEL=vision
VISION_TIMEOUT_SECS=30
ACTIONS_LOG_PATH=logs/actions.jsonl

# Linux desktop runtime passthrough
DISPLAY=
WAYLAND_DISPLAY=
XDG_RUNTIME_DIR=

# ── Phase 5: lumyn ────────────────────────────────────────────────────
SCREEN_AGENT_URL=http://screen-agent:8000
LUMYN_MODEL_GATEWAY_URL=http://model-gateway:8000
LUMYN_WORKFLOW_ENGINE_URL=http://workflow-engine:8000
LUMYN_HOST=0.0.0.0
LUMYN_PORT=11436
LUMYN_CHROMA_PATH=/app/data/chroma
LUMYN_LEARNINGS_FILE=/app/config/agent-learnings.jsonl

# ── Desktop shell / aqua-shell ───────────────────────────────────────────────
AQUA_MODEL_GATEWAY_URL=http://model-gateway:8000
AQUA_WORKFLOW_ENGINE_URL=http://workflow-engine:8000
