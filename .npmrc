# NPM Configuration for Reproducible Builds
# This file ensures consistent package installations across environments

# Force clean installs in CI environments
ci=true

# Disable peer dependency conflicts (stricter dependency resolution)
legacy-peer-deps=false

# Use cached packages when available (for faster builds)
prefer-offline=true

# Ensure all package versions are from lock file
frozen-lockfile=true

# Save exact versions to lock file (no ranges)
save-exact=false

# Set node_modules installation method
install-strategy=nested

# Production-specific settings
production=false

# Security settings
audit=true
audit-level=moderate

# Build optimization
progress=true
